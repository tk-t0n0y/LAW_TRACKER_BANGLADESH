# Ignore all files and directories by default
*

# Allow the .gitignore file itself
!/.gitignore

# Allow the .github directory and all its contents
!/.github/
!/.github/**

# Allow the script, database, and README in the root
!/track_bdlaws.py
!/laws_database.json
!/README.md

# Explicitly ignore python cache and compiled files inside allowed directories
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
